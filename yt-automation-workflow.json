            ]
        },
        {
            "parameters": {
                "resource": "video",
                "operation": "upload",
                "title": "={{ $('Parse AI Output').item.json.title + ' #Shorts' }}",
                "description": "={{ $('Parse AI Output').item.json.description }}",
                "categoryId": "27",
                "privacyStatus": "public",
                "binaryProperty": "data",
                "options": {
                    "tags": "={{ $('Parse AI Output').item.json.tags.split(',').map(t => t.trim()) }}",
                    "embeddable": true,
                    "publicStatsViewable": true,
                    "selfDeclaredMadeForKids": false,
                    "notifySubscribers": true
                }
            },
            "id": "b1a2c3d4-0007-0000-0000-000000000007",
