{
    "name": "YouTube Automation - Fully Passive (Manual + Scheduled)",
    "nodes": [
        {
            "parameters": {},
            "id": "trigger-manual-001",
            "name": "Manual Click Trigger",
            "type": "n8n-nodes-base.manualTrigger",
            "typeVersion": 1,
            "position": [
                0,
                300
            ]
        },
        {
            "parameters": {
                "rule": {
                    "interval": [
                        {
                            "field": "cronExpression",
                            "expression": "0 9 * * *"
                        }
                    ]
                }
            },
            "id": "trigger-schedule-001",
            "name": "Daily Automation (9 AM)",
            "type": "n8n-nodes-base.scheduleTrigger",
            "typeVersion": 1.1,
            "position": [
                0,
                500
            ]
        },
        {
            "parameters": {
                "jsCode": "// Niche: Money Psychology & Wealth Mindset\n// Expert-curated viral topic bank \u2014 rotates daily for freshness\nconst topics = [\n  \"The psychological reason why most people will never be rich\",\n  \"3 money habits millionaires practice before 7AM that nobody talks about\",\n  \"Why your brain is secretly wired to stay broke (and how to rewire it)\",\n  \"The dark truth about why billionaires think completely differently about time\",\n  \"The 5-second habit that separates the wealthy from everyone else\",\n  \"Why most people are one decision away from wealth but never make it\",\n  \"The psychological trap keeping 90% of people financially stuck forever\",\n  \"How the rich use boredom as a superpower to build generational wealth\",\n  \"The money mindset Warren Buffett used at age 11 that changed everything\",\n  \"3 things poor people spend money on that rich people never do\",\n  \"The silent wealth killer hiding in your daily routine right now\",\n  \"Why the richest people in the world work less than you think\",\n  \"The compound effect secret that the wealthy never teach in schools\",\n  \"How top 1% earners protect their mind to protect their money\",\n  \"The psychological reason lottery winners go broke within 5 years\",\n  \"What your relationship with money reveals about your subconscious beliefs\",\n  \"Why getting a raise actually makes most people poorer in the long run\",\n  \"The one investment the ultra-wealthy make that the middle class ignores\",\n  \"How delayed gratification literally rewires your brain for wealth\",\n  \"The dark psychology behind why banks want you to stay in debt forever\",\n  \"3 cognitive biases keeping you from building serious wealth right now\",\n  \"Why the middle class works harder but the wealthy work smarter (the math)\",\n  \"The identity shift every millionaire makes before their first million\",\n  \"What studying 1000 millionaires revealed about their morning routine\",\n  \"The financial decision you make at 22 that determines your entire future\",\n  \"How rich people use other people's money to build their wealth\",\n  \"The tax secret the ultra-wealthy use that your accountant won't tell you\",\n  \"Why most financial advice is designed to keep you middle class forever\",\n  \"The abundance mindset vs scarcity mindset: what neuroscience actually says\",\n  \"3 books that changed how millionaires think about money before age 30\"\n];\n\n// Pick today's topic based on day of year (rotates automatically)\nconst dayOfYear = Math.floor((new Date() - new Date(new Date().getFullYear(), 0, 0)) / 86400000);\nconst topic = topics[dayOfYear % topics.length];\n\nreturn [{ json: { topic: topic } }];"
            },
            "id": "node-topic-bank-001",
            "name": "Money Psychology Topic Bank",
            "type": "n8n-nodes-base.code",
            "typeVersion": 2,
            "position": [
                260,
                400
            ]
        },
        {
            "parameters": {
                "jsCode": "const topic = $input.first().json.topic;\n\nconst system = \"You are a viral YouTube Shorts scriptwriter specializing in Money Psychology & Wealth Mindset. You MUST return ONLY valid JSON with no extra text, markdown, or code blocks.\";\n\nconst prompt = `Create a complete YouTube Shorts package for this topic: ${topic}\\n\\nRules:\\n- Script: 60-80 words max, punchy, hook in first 3 words\\n- Title: max 60 chars, curiosity-gap style, NO emojis\\n- Description: 3-4 sentences + 15 relevant hashtags including #Shorts #MoneyPsychology #WealthMindset\\n- Tags: comma-separated list of 15 specific tags (no #)\\n- on_screen_title: 2-3 words MAX, all caps\\n\\nReturn ONLY this JSON object:\\n{\\n  \\"script\\": \\"...\\",\\n  \\"title\\": \\"...\\",\\n  \\"description\\": \\"...\\",\\n  \\"tags\\": \\"...\\",\\n  \\"on_screen_title\\": \\"...\\"\\n}`;\n\nreturn [{ \n  json: { \n    model: \"llama3\",\n    stream: false,\n    system: system,\n    prompt: prompt\n  } \n}];"
            },
            "id": "node-build-body-001",
            "name": "Build Safe Ollama Body",
            "type": "n8n-nodes-base.code",
            "typeVersion": 2,
            "position": [
                520,
                400
            ]
        },
        {
            "parameters": {
                "method": "POST",
                "url": "http://host.docker.internal:11434/api/generate",
                "sendHeaders": true,
                "headerParameters": {
                    "parameters": [
                        {
                            "name": "Content-Type",
                            "value": "application/json"
                        }
                    ]
                },
                "sendBody": true,
                "specifyBody": "json",
                "options": {
                    "timeout": 300000
                },
                "jsonBody": "={{ $json }}"
            },
            "id": "b1a2c3d4-0002-0000-0000-000000000002",
            "name": "Ollama Script & Strategy",
            "type": "n8n-nodes-base.httpRequest",
            "typeVersion": 4.2,
            "position": [
                780,
                400
            ]
        },
        {
            "parameters": {
                "jsCode": "// \ud83c\udfc6 BULLETPROOF REGEX PARSER - N8N\nconst items = $input.all();\nif (items.length === 0 || !items[0].json || !items[0].json.response) {\n  return [{ json: { error: \"No response from AI yet\" } }];\n}\n\nconst raw = items[0].json.response;\n\n// This function \"hunts\" for data even in broken JSON\nfunction extract(key, text) {\n  // Look for \"key\": \"value\" and grab the value\n  const regex = new RegExp(`\"${key}\"\\\\s*:\\\\s*\"([\\\\s\\\\S]*?)(?=\"\\\\s*[,}])`, 'g');\n  const match = regex.exec(text);\n  if (match && match[1]) {\n    return match[1]\n      .replace(/\\\\n/g, '\\n')   // Fix line breaks\n      .replace(/\\\\\"/g, '\"')    // Fix quotes\n      .replace(/\\\\r/g, '')     // Clean up\n      .trim();\n  }\n  return '';\n}\n\n// Extract every field individually\nconst script = extract('script', raw);\nconst title = extract('title', raw);\nconst description = extract('description', raw);\nconst tags = extract('tags', raw).replace(/[\\[\\]]/g, ''); // Clean arrays if AI uses them\nconst on_screen = extract('on_screen_title', raw);\n\nreturn [{\n  json: {\n    script: script || 'Script generation failed',\n    title: title || 'Deep Wealth Secret',\n    description: description || '#MoneyPsychology #WealthMindset',\n    tags: tags || 'money, psychology',\n    on_screen_title: (on_screen || 'MONEY FACT').toUpperCase(),\n    timestamp: new Date().toISOString()\n  }\n}];"
            },
            "id": "b1a2c3d4-0003-0000-0000-000000000003",
            "name": "Parse AI Output",
            "type": "n8n-nodes-base.code",
            "typeVersion": 2,
            "position": [
                1040,
                400
            ]
        },
        {
            "parameters": {
                "method": "POST",
                "url": "http://host.docker.internal:5001/tts",
                "sendHeaders": true,
                "headerParameters": {
                    "parameters": [
                        {
                            "name": "Content-Type",
                            "value": "application/json"
                        }
                    ]
                },
                "sendBody": true,
                "specifyBody": "json",
                "jsonBody": "={{ JSON.stringify({ \"text\": $json.script, \"title\": $json.on_screen_title }) }}",
                "options": {
                    "timeout": 300000
                }
            },
            "id": "b1a2c3d4-0004-0000-0000-000000000004",
            "name": "Generate Video (Flask TTS)",
            "type": "n8n-nodes-base.httpRequest",
            "typeVersion": 4.2,
            "position": [
                1300,
                400
            ]
        },
        {
            "parameters": {
                "conditions": {
                    "options": {
                        "caseSensitive": true,
                        "leftValue": "",
                        "typeValidation": "strict"
                    },
                    "conditions": [
                        {
                            "id": "cond-1",
                            "leftValue": "={{ $json.status }}",
                            "rightValue": "success",
                            "operator": {
                                "type": "string",
                                "operation": "equals"
                            }
                        }
                    ],
                    "combinator": "and"
                },
                "options": {}
            },
            "id": "b1a2c3d4-0005-0000-0000-000000000005",
            "name": "Video Generated OK?",
            "type": "n8n-nodes-base.if",
            "typeVersion": 2.1,
            "position": [
                1560,
